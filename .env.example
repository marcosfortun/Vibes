# Variables de entorno de Vibes — PLANTILLA
#
# Copia este fichero a `.env.local` y rellena los valores para desarrollo local.
# `.env.local` está en .gitignore: NUNCA se commitea.
# En producción, estas variables se configuran en el panel de Vercel
# (Project Settings → Environment Variables), no en ningún fichero.
#
# Convención Next.js:
# - Las `NEXT_PUBLIC_*` se incrustan en el bundle del navegador (son públicas).
# - El resto son SOLO de servidor (secretos): nunca las prefijes con NEXT_PUBLIC_.

# ── Supabase ────────────────────────────────────────────────────────────────
# Local: el stack del Supabase CLI (`supabase start`).
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Producción: la URL del proyecto en Supabase Cloud.
#   NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Clave anónima (protegida por RLS; se expone en el cliente por diseño).
# Local: la imprime `supabase start` / `supabase status`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service-role (SECRETO de servidor; OMITE la RLS).
# Solo la usa el cliente admin (src/lib/supabase/admin.ts), p. ej. para leer
# emails de usuarios al enviar notificaciones. NUNCA exponer en el navegador.
SUPABASE_SERVICE_ROLE_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# API key de Resend (SECRETO). Su PRESENCIA decide el proveedor de envío:
#   - vacío/ausente  → se usa Mailpit (desarrollo local, sin correos reales).
#   - con valor      → se usa Resend (producción).
RESEND_API_KEY=

# Remitente unificado de los correos.
EMAIL_FROM="Vibes <onboarding@resend.dev>"

# URL del API de Mailpit en local (opcional; por defecto http://localhost:54324).
# Solo relevante en desarrollo, cuando RESEND_API_KEY está vacío.
# MAILPIT_API_URL=http://localhost:54324

# ── App ───────────────────────────────────────────────────────────────────────
# URL base de la app: enlaces de los correos y redirects de auth.
# Local: http://localhost:3000 — Producción: la URL de Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
